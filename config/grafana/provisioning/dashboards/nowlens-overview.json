{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "NowLens AI Overview",
  "tags": ["nowlens"],
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "HTTP request rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (path) (rate(nowlens_http_requests_total[5m]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP p95 latency (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(nowlens_http_request_seconds_bucket[5m])))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Agent runs by intent",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (intent) (rate(nowlens_agent_runs_total[15m]))",
          "legendFormat": "{{intent}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Retrieval p95 latency (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(nowlens_retrieval_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
