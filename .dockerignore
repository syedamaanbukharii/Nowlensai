# Version control
.git/
.gitignore

# Python caches & build artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml

# Virtual environments
.venv/
venv/
env/

# Tests & docs (not needed in the runtime image)
tests/
docs/
*.md
!README.md

# Local env / data
.env
.env.*
!.env.example
data/local/
*.sqlite*
*.db
*.log

# Frontend (built separately)
frontend/node_modules/
frontend/.next/
frontend/out/

# Editors / OS
.idea/
.vscode/
.DS_Store
