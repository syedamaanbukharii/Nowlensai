# ---------------------------------------------------------------------------
# NowLens AI — example environment configuration
#
# Copy to `.env` and adjust. Every variable uses the NOWLENS_ prefix; nested
# settings groups use a double underscore, e.g. NOWLENS_RAG__FINAL_TOP_K.
# Defaults shown here match the application defaults and work for local Docker.
# ---------------------------------------------------------------------------

# ---- Core ----
NOWLENS_ENVIRONMENT=development            # development | staging | production
NOWLENS_APP_NAME=NowLens AI
NOWLENS_DEBUG=false
# Comma-separated list of allowed CORS origins:
NOWLENS_CORS_ORIGINS=http://localhost:3000

# ---- Datastores ----
NOWLENS_DATABASE_URL=postgresql+asyncpg://nowlens:nowlens@localhost:5432/nowlens
NOWLENS_REDIS_URL=redis://localhost:6379/0
NOWLENS_QDRANT_URL=http://localhost:6333
# NOWLENS_QDRANT_API_KEY=

# ---- LLM / embeddings ----
NOWLENS_LLM__PROVIDER=ollama               # chat backend: ollama | groq
NOWLENS_LLM__OLLAMA_BASE_URL=http://localhost:11434
NOWLENS_LLM__OLLAMA_CHAT_MODEL=llama3.1:8b
NOWLENS_LLM__OLLAMA_EMBED_MODEL=nomic-embed-text
NOWLENS_LLM__EMBEDDING_DIM=768             # must match the embed model + Qdrant collection size
# Required only when NOWLENS_LLM__PROVIDER=groq:
# NOWLENS_LLM__GROQ_API_KEY=
NOWLENS_LLM__GROQ_CHAT_MODEL=llama-3.1-70b-versatile

# Embedding backend (independent of the chat provider): ollama | openai
NOWLENS_LLM__EMBEDDING_PROVIDER=ollama
# OpenAI-compatible embeddings (OpenAI, Azure gateway, Together, vLLM, ...).
# Used only when NOWLENS_LLM__EMBEDDING_PROVIDER=openai. The model must support
# the `dimensions` parameter so its output matches NOWLENS_LLM__EMBEDDING_DIM.
# NOWLENS_LLM__OPENAI_API_KEY=
NOWLENS_LLM__OPENAI_EMBED_BASE_URL=https://api.openai.com/v1
NOWLENS_LLM__OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- Retrieval (RAG) ----
NOWLENS_RAG__COLLECTION=nowlens_docs
NOWLENS_RAG__VECTOR_TOP_K=20
NOWLENS_RAG__LEXICAL_TOP_K=20
NOWLENS_RAG__RRF_K=60
NOWLENS_RAG__RERANK_CANDIDATES=20
NOWLENS_RAG__FINAL_TOP_K=6
NOWLENS_RAG__USE_CROSS_ENCODER=false       # requires the `rerank` extra
# NOWLENS_RAG__CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
NOWLENS_RAG__COMPRESSION_ENABLED=true
NOWLENS_RAG__COMPRESSION_RATIO=0.6

# ---- Ingestion ----
NOWLENS_INGEST__USER_AGENT=NowLensBot/0.1 (+https://example.com/nowlens)
NOWLENS_INGEST__CHUNK_SIZE=1200
NOWLENS_INGEST__CHUNK_OVERLAP=200
NOWLENS_INGEST__MIN_CHUNK_CHARS=120
NOWLENS_INGEST__SIMHASH_MAX_DISTANCE=3
NOWLENS_INGEST__RENDER_JAVASCRIPT=false    # requires the `render` extra + playwright
NOWLENS_INGEST__AI_CLEANING=true           # LLM-assisted cleaning; degrades to rules on failure
NOWLENS_INGEST__MAX_DOCUMENT_BYTES=5000000 # hard cap on a single fetched response body

# ---- Security ----
# CHANGE THIS in any non-local environment — used to sign JWTs. In production
# the app refuses to start unless this is a strong secret of >=32 characters
# (the placeholder below is rejected). Generate one with e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
NOWLENS_SECURITY__JWT_SECRET=dev-insecure-change-me
# Auth cookies (HttpOnly access/refresh + readable CSRF). Set COOKIE_SECURE=true
# in production; use SAMESITE=none (+ Secure) only for a cross-site frontend.
NOWLENS_SECURITY__COOKIE_SECURE=false
NOWLENS_SECURITY__COOKIE_SAMESITE=lax
# NOWLENS_SECURITY__COOKIE_DOMAIN=
NOWLENS_SECURITY__JWT_ALGORITHM=HS256
NOWLENS_SECURITY__ACCESS_TOKEN_TTL_MIN=30
NOWLENS_SECURITY__REFRESH_TOKEN_TTL_DAYS=14
NOWLENS_SECURITY__RATE_LIMIT_PER_MINUTE=60
NOWLENS_SECURITY__RATE_LIMIT_BURST=20
NOWLENS_SECURITY__MAX_INPUT_CHARS=8000

# ---- Monitoring stack (docker-compose only) ----
# Overrides the Grafana admin credentials; defaults are for local dev only.
# NOWLENS_GRAFANA_ADMIN_USER=admin
# NOWLENS_GRAFANA_ADMIN_PASSWORD=admin

# ---- Observability ----
NOWLENS_OBS__LOG_LEVEL=INFO
NOWLENS_OBS__LOG_JSON=true
NOWLENS_OBS__LANGFUSE_ENABLED=false        # requires the `langfuse` extra
# NOWLENS_OBS__LANGFUSE_PUBLIC_KEY=
# NOWLENS_OBS__LANGFUSE_SECRET_KEY=
# NOWLENS_OBS__LANGFUSE_HOST=https://cloud.langfuse.com
